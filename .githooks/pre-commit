#!/bin/bash
# Pre-commit hook: 检查即将提交的内容中是否包含个人敏感信息
#
# 敏感模式定义在 .githooks/sensitive-patterns 中（每行一个正则）
# 该文件已被 .gitignore 忽略，不会提交到仓库
# 首次 clone 后需要自行创建，示例见 .githooks/sensitive-patterns.example

PATTERNS_FILE="$(git rev-parse --show-toplevel)/.githooks/sensitive-patterns"

if [ ! -f "$PATTERNS_FILE" ]; then
    exit 0
fi

FOUND=0
while IFS= read -r pattern || [ -n "$pattern" ]; do
    # 跳过空行和注释
    [[ -z "$pattern" || "$pattern" == \#* ]] && continue

    matches=$(git diff --cached --diff-filter=ACMR -U0 | grep "^\+" | grep -v "^+++" | grep -iE "$pattern" || true)
    if [ -n "$matches" ]; then
        if [ "$FOUND" -eq 0 ]; then
            echo "=========================================="
            echo " COMMIT BLOCKED: 检测到敏感个人信息"
            echo "=========================================="
            FOUND=1
        fi
        echo ""
        echo "匹配模式: $pattern"
        echo "$matches"
    fi
done < "$PATTERNS_FILE"

if [ "$FOUND" -ne 0 ]; then
    echo ""
    echo "请移除上述内容后重新提交。"
    echo "如确认无风险，可使用 git commit --no-verify 跳过检查。"
    exit 1
fi
